# ── Server ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production  # or 'development'

# ── Security (REQUIRED in production) ───────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
ADMIN_CLEANUP_TOKEN=CHANGE_ME_strong_random_value
ALLOWED_ORIGINS=https://printhub.hospital.internal,http://localhost:5173

# ── Database ─────────────────────────────────────
DATABASE_PATH=./printhub.db
DATABASE_BACKUP_PATH=./backups/

# ── Agent ────────────────────────────────────────
SERVER_URL=http://127.0.0.1:8000
HEARTBEAT_INTERVAL=15
STALE_THRESHOLD_SECONDS=45

# ── Print settings ───────────────────────────────
MAX_RETRY_COUNT=3
JOB_LOCK_TIMEOUT_SECONDS=300

# ── Alerts (optional) ────────────────────────────
ALERT_EMAIL_FROM=alerts@hospital.internal
ALERT_EMAIL_TO=it-support@hospital.internal
SMTP_HOST=smtp.hospital.internal
SMTP_PORT=587
