# ── Server ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
# Set ENVIRONMENT=production on a real hospital server

# ── Security (REQUIRED) ─────────────────────────
# Generate JWT_SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
ADMIN_CLEANUP_TOKEN=CHANGE_ME_strong_random_value

# ── CORS — allowed browser origins ──────────────
# Add your server's IP here so the dashboard works from other PCs on the network.
# Replace 192.168.1.14 with your actual server IP.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.14:5173

# ── Database ─────────────────────────────────────
DATABASE_PATH=./printhub.db
DATABASE_BACKUP_PATH=./backups/

# ── Agent heartbeat threshold ────────────────────
STALE_THRESHOLD_SECONDS=45

# ── Print settings ───────────────────────────────
MAX_RETRY_COUNT=3
JOB_LOCK_TIMEOUT_SECONDS=300

# ── Alerts (optional) ────────────────────────────
ALERT_EMAIL_FROM=alerts@hospital.internal
ALERT_EMAIL_TO=it-support@hospital.internal
SMTP_HOST=smtp.hospital.internal
SMTP_PORT=587
